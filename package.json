{
  "name": "nacionpay-backend",
  "version": "1.0.0",
  "description": "NaciónPay - Sistema de Billetera Digital del Banco de la Nación",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "eslint": "^8.42.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "lines": 75
      }
    },
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js"
    ]
  }
}
