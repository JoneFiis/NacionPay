{
  "name": "nacionpay-backend",
  "version": "1.0.0",
  "description": "NaciónPay - Sistema de Billetera Digital - Banco de la Nación del Perú",
  "main": "src/app.js",
  "scripts": {
    "test": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":75}}'",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "start": "node src/app.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
